{
  "name": "lyte-pen",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.2.2",
      "zod": "^4.1.13",
      "typescript": "^5",
      "@types/bun": "^1.3.4",
      "@cloudflare/workers-types": "^4.20251213.0",
      "hono": "^4.8.2",
      "@orpc/server": "^1.12.2",
      "@orpc/openapi": "^1.12.2",
      "@orpc/zod": "^1.12.2",
      "better-auth": "^1.4.18",
      "@prisma/client": "^7.2.0",
      "@orpc/tanstack-query": "^1.12.2",
      "@orpc/client": "^1.12.2",
      "@tanstack/react-query": "^5.90.12",
      "@tanstack/react-form": "^1.28.0",
      "@polar-sh/better-auth": "^1.6.4",
      "alchemy": "^0.82.1",
      "@better-auth/expo": "^1.4.18"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:native": "turbo -F native dev",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @lyte-pen/db db:push",
    "db:studio": "turbo -F @lyte-pen/db db:studio",
    "db:generate": "turbo -F @lyte-pen/db db:generate",
    "db:migrate": "turbo -F @lyte-pen/db db:migrate",
    "db:start": "turbo -F @lyte-pen/db db:start",
    "db:watch": "turbo -F @lyte-pen/db db:watch",
    "db:stop": "turbo -F @lyte-pen/db db:stop",
    "db:down": "turbo -F @lyte-pen/db db:down",
    "deploy": "turbo -F @lyte-pen/infra deploy",
    "destroy": "turbo -F @lyte-pen/infra destroy",
    "check": "ultracite check",
    "fix": "ultracite fix",
    "prepare": "husky",
    "ruler:apply": "bunx @intellectronica/ruler@latest apply --local-only",
    "clean": "find . -name node_modules -type d -prune -exec rm -rf {} +",
    "clean:full": "find . -name node_modules -type d -prune -exec rm -rf {} + && rm -f bun.lock"
  },
  "dependencies": {
    "@lyte-pen/env": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "2.3.13",
    "@cloudflare/workers-types": "catalog:",
    "@lyte-pen/config": "workspace:*",
    "@types/bun": "catalog:",
    "husky": "latest",
    "lefthook": "latest",
    "lint-staged": "latest",
    "turbo": "^2.6.3",
    "typescript": "catalog:",
    "ultracite": "7.1.5"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,jsonc,css,scss,md,mdx}": [
      "bun x ultracite fix"
    ]
  },
  "packageManager": "bun@1.3.9"
}
